{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "termini",
  "version": "0.2.0",
  "identifier": "com.user.termini",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "termini",
        "width": 800,
        "height": 600,
        "decorations": false,
        "visible": true,
        "backgroundColor": "#191d2d"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkyNEE3OURENDBBQTI1MjIKUldRaUphcEEzWGxLa3FEdkJESzJOaTUvK1dNSm9lak1XQ2RNN1NkRXI4WW82VG4wWWtNZjUxOTgK",
      "endpoints": [
        "https://github.com/mark0613/termini/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
